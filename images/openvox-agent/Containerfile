# Minimal OpenVox Agent for testing against openvox-operator
#
# Build:
#   podman build -t openvox-agent:latest images/openvox-agent/
#
# Run:
#   podman run --rm openvox-agent:latest agent --test --server puppet

# renovate: datasource=github-releases depName=OpenVoxProject/openvox-agent versioning=loose
ARG OPENVOX_AGENT_VERSION=8.25.0

FROM registry.access.redhat.com/ubi9/ubi:9.7-1773895171

ARG OPENVOX_AGENT_VERSION

RUN rpm -Uvh https://yum.voxpupuli.org/openvox8-release-el-9.noarch.rpm \
    && dnf install -y --setopt=install_weak_deps=False openvox-agent-${OPENVOX_AGENT_VERSION} \
    && dnf clean all

ENV PATH="/opt/puppetlabs/bin:${PATH}"

ENTRYPOINT ["/opt/puppetlabs/bin/puppet"]
