# Mock ENC / report / OpenVox DB receiver for E2E tests
#
# Build (from repo root):
#   podman build -t openvox-mock:latest -f images/openvox-mock/Containerfile .

FROM docker.io/library/golang:1.26.2 AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/mock/ cmd/mock/
RUN CGO_ENABLED=0 go build -o /openvox-mock ./cmd/mock/

FROM registry.access.redhat.com/ubi9/ubi-minimal:9.7-1776104705

LABEL org.opencontainers.image.title="OpenVox Mock" \
      org.opencontainers.image.description="Mock ENC/Report/OpenVox DB receiver for E2E tests" \
      org.opencontainers.image.vendor="slauger" \
      org.opencontainers.image.url="https://github.com/slauger/openvox-operator" \
      org.opencontainers.image.source="https://github.com/slauger/openvox-operator" \
      org.opencontainers.image.licenses="Apache-2.0"

COPY --from=builder /openvox-mock /openvox-mock

USER 1001:0

EXPOSE 8080

ENTRYPOINT ["/openvox-mock"]
